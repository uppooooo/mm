<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="robots" content="noindex,nofollow,noarchive">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>スキルSP計算</title>

  <link rel="stylesheet" href="./styles.css">
</head>

<body>
<div class="container">
  <header>
    <h1>スキルSP計算</h1>
    <p>取得したいスキルLvを選択すると、必要SPを計算します。</p>
  </header>

  <main>
    <!-- 所有SP -->
    <form class="form-grid cols-1" novalidate>
      <label class="label">所有SP</label>
      <input id="ownSP" class="fld" type="number" min="0" inputmode="numeric">
    </form>

    <div class="divider"></div>

    <!-- スキル表 -->
    <h2>スキル選択</h2>

    <table class="skill-table">
      <thead>
        <tr>
          <th>区分</th>
          <th>スキル</th>
          <th>Lv</th>
          <th class="sp">必要SP</th>
          <th class="mp">消費MP</th>
          <th>2次条件</th>
        </tr>
      </thead>
      <tbody id="skillBody"></tbody>
    </table>

    <p id="warn" style="color:#dc2626;font-weight:600;"></p>

    <div class="divider"></div>

    <!-- 結果 -->
    <h2>結果</h2>
    <section class="result-panel">
      <div class="row">取得スキル：</div>
      <ul id="resultList"></ul>

      <div class="row total">消費SP：<span id="usedSP">0</span></div>
      <div class="row total">残りSP：<span id="remainSP">0</span></div>
    </section>

    <ul>
      <li><a href="./index.html">トップページ</a></li>
    </ul>
  </main>
</div>

<script>
(function(){
  const skills = [
    { tier:1, name:'シェル', sp:[3,8,16,24,35,46,60], mp:[7,12,18,25,33,43,55], need:['ナイトメア','スロウフォース'] },
    { tier:1, name:'カウンター', sp:[3,8,16,24,35,46,60], mp:[7,12,18,25,33,43,55] },
    { tier:1, name:'シールド', sp:[5,12,22,35,50], mp:[10,20,30,40,50], need:['ナイトメア','スロウフォース'] },
    { tier:1, name:'ブレス', sp:[5,13,25,42,65], mp:[15,25,35,50,65], need:['プロミネンス'] },

    { tier:2, name:'プロミネンス', sp:[15,45], mp:[70,100], reqFirst:['ブレス'] },
    { tier:2, name:'ナイトメア', sp:[5,15,25,40,55], mp:[40,50,60,70,80], reqFirst:['シェル','シールド','スナッチ','ストライク'] }
  ];

  const body = document.getElementById('skillBody');
  const usedSP = document.getElementById('usedSP');
  const remainSP = document.getElementById('remainSP');
  const ownSP = document.getElementById('ownSP');
  const warn = document.getElementById('warn');
  const list = document.getElementById('resultList');

  function render(){
    body.innerHTML = '';
    skills.forEach((s,i)=>{
      const tr=document.createElement('tr');
      tr.innerHTML = `
        <td>${s.tier===1?'1次':'2次'}</td>
        <td>${s.name}</td>
        <td>
          <select data-i="${i}">
            <option value="">-</option>
            ${s.sp.map((_,lv)=>`<option value="${lv}">Lv${lv+1}</option>`).join('')}
          </select>
        </td>
        <td class="sp" id="sp-${i}">-</td>
        <td class="mp" id="mp-${i}">-</td>
        <td>${s.reqFirst? s.reqFirst.join('/') : s.need? s.need.join('/') : ''}</td>
      `;
      body.appendChild(tr);
    });
  }

  function calc(){
    let totalSP=0;
    warn.textContent='';
    list.innerHTML='';

    const selected = {};
    document.querySelectorAll('select').forEach(sel=>{
      if(sel.value!==''){
        selected[sel.dataset.i]=+sel.value;
      }
    });

    // 判定
    for(const i in selected){
      const s = skills[i];
      const lv = selected[i];
      document.getElementById(`sp-${i}`).textContent = s.sp[lv];
      document.getElementById(`mp-${i}`).textContent = s.mp[lv];
      totalSP += s.sp[lv];

      // 2次条件チェック
      if(s.tier===2){
        const ok = s.reqFirst.some(f=>{
          return Object.keys(selected).some(j=>{
            return skills[j].name===f && selected[j]===skills[j].sp.length-1;
          });
        });
        if(!ok){
          warn.textContent='2次スキル取得条件（1次スキル最大Lv）を満たしていません。';
        }
      }

      const li=document.createElement('li');
      li.textContent=`${s.name} Lv${lv+1}（MP ${s.mp[lv]}）`;
      list.appendChild(li);
    }

    usedSP.textContent = totalSP;
    remainSP.textContent = Math.max(0,(+ownSP.value||0) - totalSP);
  }

  render();
  document.addEventListener('input', calc);
})();
</script>
</body>
</html>
``
